# MarketSpy AI Configuration
# Copy this to .env and adjust as needed

# Ollama/Qwen Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_GENERATE_URL=http://localhost:11434/api/generate
AI_ALLOW_FALLBACK=true
AI_TIMEOUT_SECONDS=240
AI_BATCH_SIZE=20

# FastAPI/Server Configuration
SECRET_KEY=your-secret-key-here

# Scraper Configuration
SCRAPER_HEADLESS=False
SCRAPER_MAX_RETRIES=3
SCRAPER_RETRY_DELAY=2
SCRAPER_MAX_HALAMAN=2
REQUESTED_COUNT_DEFAULT=25
OVERFETCH_MULTIPLIER=4
MAX_RAW_CANDIDATES=300
MAX_SCROLL_ATTEMPTS=30
MIN_ACCEPTED_RATIO_WARNING=0.25
PUPPETEER_PROCESS_TIMEOUT_SECONDS=240
PUPPETEER_IDLE_TIMEOUT_SECONDS=90
